{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "dom"],
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@ngx-zen/mat-password-meter": ["./src/public-api.ts"],
      "@ngx-zen/mat-password-meter/strength": ["./src/strength/index.ts"],
      "@ngx-zen/mat-password-meter/rules": ["./src/rules/index.ts"],
      "@ngx-zen/mat-password-meter/analysis": ["./src/analysis/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  },
  "exclude": ["**/*.spec.ts", "dist", "demo", "node_modules"]
}
