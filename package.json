{
  "name": "@ngx-zen/mat-password-meter-workspace",
  "private": true,
  "version": "2.0.1",
  "description": "Development workspace for @ngx-zen/mat-password-meter",
  "author": "Peter Adison",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngx-zen/mat-password-meter.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "ng-packagr -p src/ng-package.json && node -e \"const fs=require('fs');fs.copyFileSync('README.md','dist/README.md');fs.copyFileSync('LICENSE','dist/LICENSE')\"",
    "pack": "npm run build && npm pack --pack-destination demo ./dist && node scripts/pack.mjs",
    "pack:test": "npm run pack && npm install --prefix demo && npm run build --prefix demo",
    "demo": "npm run pack:test && npx serve demo/dist/demo/browser",
    "dev": "npm install --prefix demo && npm start --prefix demo -- --configuration source",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/cli": "^20.3.21",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@types/jest": "^30.0.0",
    "@types/zxcvbn": "^4.4.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.1",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^20.3.2",
    "prettier": "^3.8.1",
    "typescript": "~5.8.3",
    "zone.js": "^0.15.1",
    "zxcvbn": "^4.4.2"
  },
  "sideEffects": false,
  "lint-staged": {
    "src/**/*.{ts,html,scss,json}": "prettier --check",
    "demo/src/**/*.{ts,html,scss}": "prettier --check"
  }
}
